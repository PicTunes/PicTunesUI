    </dict>

    <!-- Facebook / Instagram Stories 分享必须的 App ID -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>fb1377558706877252</string>
            </array>
        </dict>
    </array>
    <key>FacebookAppID</key>
    <string>1377558706877252</string>
